# ── Azure Blob & Table Storage ────────────────────────────────────────────────
# Only AZURE_STORAGE_ACCOUNT is required for local dev — `az login` handles auth.
AZURE_STORAGE_ACCOUNT=

# Service Principal (optional — for CI/CD or serverless deployments)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Leave empty to use ~/.aws/credentials or an IAM role automatically.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional: comma-separated allowlist of bucket names (empty = all buckets)
S3_ALLOWED_BUCKETS=

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_WAREHOUSE_ID=

# PAT auth (simplest for local dev)
DATABRICKS_TOKEN=

# OAuth M2M (recommended for production)
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# ── General ───────────────────────────────────────────────────────────────────
MAX_QUERY_ROWS=5000

# Set to "http" to run as a remote HTTP connector instead of stdio
TRANSPORT=stdio
